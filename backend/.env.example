# Flask environment variables
PORT=5000
DEBUG=True
SECRET_KEY=dev-secret-key-change-this-in-production
JWT_SECRET_KEY=jwt-dev-secret-key-change-this-in-production

# Database Configuration (Defaults to SQLite in backend/instance/interviewace.db)
# To use PostgreSQL, set this to your connection string:
# DATABASE_URL=postgresql://username:password@localhost:5432/interviewace

# OpenAI API Key (Required for AI generation; falls back to offline heuristics if left empty)
OPENAI_API_KEY=

# Google OAuth 2.0 Client ID (Required for Google login; falls back to local user registry if left empty)
GOOGLE_CLIENT_ID=
